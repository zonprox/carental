# ========================================
# CarRental Frontend Environment Configuration
# ========================================
# Copy this file to .env and update values for your environment

# ========================================
# APPLICATION SETTINGS
# ========================================
NODE_ENV=development

# ========================================
# API CONFIGURATION
# ========================================
# Backend API URL (adjust based on your backend deployment)
VITE_API_URL=http://localhost:5000/api

# ========================================
# PRODUCTION SETTINGS
# ========================================
# For production deployment, update these values:
# VITE_API_URL=https://your-domain.com/api

# ========================================
# OPTIONAL FEATURES (uncomment to enable)
# ========================================

# Analytics
# VITE_GOOGLE_ANALYTICS_ID=your-ga-id-here

# Error Tracking
# VITE_SENTRY_DSN=your-sentry-dsn-here

# Feature Flags
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_MONITORING=true

# ========================================
# DEVELOPMENT SETTINGS
# ========================================
# Enable development tools
VITE_DEV_TOOLS=true

# ========================================
# NOTES
# ========================================
# - All environment variables for Vite must be prefixed with VITE_
# - These variables will be exposed to the client-side code
# - Never include sensitive information in frontend environment variables
# - For production, set VITE_API_URL to your actual backend URL