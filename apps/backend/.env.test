# Test Environment Configuration
NODE_ENV=test
PORT=3001

# JWT Configuration for Testing
JWT_SECRET=test-secret-key-for-jest
JWT_EXPIRES_IN=1h

# Database Configuration for Testing
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carental_test
DB_USER=carental_user
DB_PASSWORD=carental_password
DATABASE_URL=postgresql://carental_user:carental_password@localhost:5432/carental_test

# Frontend URL for CORS (Test)
FRONTEND_URL=http://localhost:3000

# Security Settings (Test)
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100