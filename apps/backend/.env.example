# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration - PostgreSQL Only
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carental_dev
DB_USER=carental_user
DB_PASSWORD=carental_password
DATABASE_URL=postgresql://carental_user:carental_password@localhost:5432/carental_dev

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters
JWT_EXPIRES_IN=7d

# CORS Configuration (Production)
# Comma-separated list of allowed origins for production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging Configuration
LOG_LEVEL=info

# Rate Limiting Configuration
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=100

# Security Configuration
HSTS_MAX_AGE=31536000
SESSION_SECRET=your-session-secret-here-minimum-32-characters

# File Upload Limits
MAX_FILE_SIZE=1mb

# Admin Credentials (Change in production!)
ADMIN_EMAIL=admin@carental.com
ADMIN_PASSWORD=admin123

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloud Storage Configuration (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Redis Configuration (Optional - for sessions/caching)
REDIS_URL=redis://localhost:6379

# Monitoring & Analytics (Optional)
SENTRY_DSN=your-sentry-dsn-here
GOOGLE_ANALYTICS_ID=your-ga-id-here

# API Keys (Optional)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Feature Flags (Optional)
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_RATE_LIMITING=true