# ========================================
# CarRental Backend Environment Configuration
# ========================================
# Copy this file to .env and update values for your environment

# ========================================
# APPLICATION SETTINGS
# ========================================
NODE_ENV=development
PORT=5000

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carental_dev
DB_USER=carental_user
DB_PASSWORD=your_secure_password_here

# Full Database URL
DATABASE_URL=postgresql://carental_user:your_secure_password_here@localhost:5432/carental_dev

# ========================================
# SECURITY & AUTHENTICATION
# ========================================
# JWT Secret (MUST be changed in production - minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=10

# ========================================
# CORS CONFIGURATION
# ========================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Production CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========================================
# ADMIN CONFIGURATION
# ========================================
# Default admin credentials (CHANGE IN PRODUCTION!)
ADMIN_EMAIL=admin@carental.com
ADMIN_PASSWORD=admin123

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info

# ========================================
# OPTIONAL SERVICES (uncomment to enable)
# ========================================

# Redis for Sessions/Caching
# REDIS_URL=redis://localhost:6379

# Email Service
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# File Upload Service (AWS S3)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Monitoring & Analytics
# SENTRY_DSN=your-sentry-dsn-here
# GOOGLE_ANALYTICS_ID=your-ga-id-here

# Payment Processing (Stripe)
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_RATE_LIMITING=true