# Multi-stage Dockerfile for Development Environment

# Backend Development Stage
FROM node:22.20.0-alpine AS backend-dev

# Install system dependencies
RUN apk add --no-cache \
    postgresql-client \
    curl \
    bash

# Set working directory
WORKDIR /app

# Copy package files for backend
COPY apps/backend/package*.json ./apps/backend/
COPY package*.json ./

# Install dependencies
RUN npm ci --workspace=@carental/backend

# Copy backend source code
COPY apps/backend ./apps/backend

# Expose port
EXPOSE 5000

# Start command
CMD ["npm", "run", "dev", "--workspace=@carental/backend"]

# Frontend Development Stage
FROM node:22.20.0-alpine AS frontend-dev

# Install system dependencies
RUN apk add --no-cache \
    curl \
    bash

# Set working directory
WORKDIR /app

# Copy package files for frontend
COPY apps/frontend/package*.json ./apps/frontend/
COPY package*.json ./

# Install dependencies
RUN npm ci --workspace=@carental/frontend

# Copy frontend source code
COPY apps/frontend ./apps/frontend

# Expose port
EXPOSE 3000

# Start command
CMD ["npm", "run", "dev", "--workspace=@carental/frontend"]