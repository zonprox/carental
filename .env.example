# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carental_db
DB_USER=carental_user
DB_PASSWORD=carental_password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d

# Server Configuration
NODE_ENV=production
PORT=5000

# Frontend Configuration (for CORS)
# In development, use specific URL
FRONTEND_URL=http://localhost:3000
# In production, leave empty or set to * to allow all domains
# FRONTEND_URL=

# Admin Configuration (for seeding)
ADMIN_EMAIL=admin@carental.com
ADMIN_PASSWORD=admin123

# Production Database (PostgreSQL)
DATABASE_URL=postgresql://carental_user:carental_password@localhost:5432/carental_db

# Optional: Redis for session storage (if implemented)
# REDIS_URL=redis://localhost:6379

# Optional: Email service (if implemented)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: File upload service (if implemented)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Security
# BCRYPT_ROUNDS=12
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100