# ========================================
# CarRental Application Environment Configuration
# ========================================
# Copy this file to .env and update the values according to your environment
# For production deployment, use .env.production as reference

# ========================================
# APPLICATION SETTINGS
# ========================================
NODE_ENV=development
PORT=5000
APP_VERSION=2.0.0

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carental_db
DB_USER=carental_user
DB_PASSWORD=your_secure_password_here

# Full Database URL (alternative to individual settings above)
DATABASE_URL=postgresql://carental_user:your_secure_password_here@localhost:5432/carental_db

# ========================================
# SECURITY & AUTHENTICATION
# ========================================
# JWT Secret Keys (MUST be changed in production - minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d

# Password Hashing Rounds (higher = more secure but slower)
BCRYPT_ROUNDS=10

# ========================================
# CORS & FRONTEND CONFIGURATION
# ========================================
# Frontend URL for CORS (adjust based on your frontend deployment)
FRONTEND_URL=http://localhost:3000

# ========================================
# ADMIN ACCOUNT (for initial setup)
# ========================================
# Default admin credentials (CHANGE THESE IN PRODUCTION!)
ADMIN_EMAIL=admin@carental.com
ADMIN_PASSWORD=admin123

# ========================================
# RATE LIMITING & SECURITY
# ========================================
# Rate limiting settings (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# LOGGING CONFIGURATION
# ========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ========================================
# OPTIONAL SERVICES (uncomment to enable)
# ========================================

# Redis for Session Storage (if implemented)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# Email Service Configuration (for notifications)
# EMAIL_SERVICE_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# File Upload Service (Cloudinary example)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ========================================
# DEVELOPMENT SETTINGS
# ========================================
# Enable detailed error messages in development
DEBUG_MODE=true

# Mock data for development
USE_MOCK_DATA=false

# ========================================
# NOTES FOR DEPLOYMENT
# ========================================
# 1. Always change default passwords and secrets
# 2. Use strong, unique passwords for database
# 3. Set NODE_ENV=production for production deployment
# 4. Configure proper CORS origins for security
# 5. Use environment-specific values for each deployment
# 6. Never commit actual .env files to version control