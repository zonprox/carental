{
  "name": "carental-client",
  "version": "2.0.0",
  "description": "CarRental modern React frontend with latest technologies",
  "type": "module",
  "engines": {
    "node": ">=22.20.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
